SMARTFLN_ENV=development
SMARTFLN_API_HOST=127.0.0.1
SMARTFLN_API_PORT=8080
SMARTFLN_SERVICE_NAME=smartfln-api
SMARTFLN_LOG_LEVEL=info
SMARTFLN_JWT_SECRET=replace-this-secret
SMARTFLN_QR_SIGNING_SECRET=replace-this-qr-signing-secret
SMARTFLN_ACCESS_TOKEN_TTL=15m
SMARTFLN_REFRESH_TOKEN_TTL=7d
SMARTFLN_STORE_PROVIDER=memory
SMARTFLN_MONGO_URI=mongodb://127.0.0.1:27017/smartfln
SMARTFLN_MONGO_DB_NAME=smartfln
SMARTFLN_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
SMARTFLN_PUBLIC_APP_URL=http://127.0.0.1:5173
SMARTFLN_PUBLIC_API_URL=http://127.0.0.1:8080
SMARTFLN_OBJECT_STORAGE_PROVIDER=local
SMARTFLN_OBJECT_STORAGE_BUCKET=smartfln-local
SMARTFLN_R2_ACCOUNT_ID=
SMARTFLN_R2_ACCESS_KEY_ID=
SMARTFLN_R2_SECRET_ACCESS_KEY=
SMARTFLN_R2_ENDPOINT_URL=
SMARTFLN_EXPORT_RETENTION_DAYS=7
SMARTFLN_RATE_LIMIT_WINDOW_MS=60000
SMARTFLN_RATE_LIMIT_MAX=300
SMARTFLN_SEED_DEMO_USERS=true
SMARTFLN_SMS_PROVIDER=disabled
SMARTFLN_TWILIO_ACCOUNT_SID=
SMARTFLN_TWILIO_AUTH_TOKEN=
SMARTFLN_TWILIO_FROM_NUMBER=
SMARTFLN_EMAIL_PROVIDER=disabled
SMARTFLN_RESEND_API_KEY=
SMARTFLN_EMAIL_FROM=
SMARTFLN_SENTRY_DSN=
