SMARTFLN_ENV=production
SMARTFLN_API_HOST=0.0.0.0
SMARTFLN_API_PORT=8080
SMARTFLN_SERVICE_NAME=smartfln-api
SMARTFLN_LOG_LEVEL=info
SMARTFLN_JWT_SECRET=<generate-64-byte-random-secret>
SMARTFLN_QR_SIGNING_SECRET=<generate-64-byte-random-secret>
SMARTFLN_ACCESS_TOKEN_TTL=15m
SMARTFLN_REFRESH_TOKEN_TTL=7d
SMARTFLN_STORE_PROVIDER=mongo
SMARTFLN_MONGO_URI=mongodb+srv://<username>:<password>@fln.eyofeum.mongodb.net/smartfln_prod?retryWrites=true&w=majority&appName=Fln
SMARTFLN_MONGO_DB_NAME=smartfln_prod
SMARTFLN_CORS_ORIGINS=https://smartfln.vercel.app
SMARTFLN_PUBLIC_APP_URL=https://smartfln.vercel.app
SMARTFLN_PUBLIC_API_URL=https://api-smartfln.onrender.com
SMARTFLN_OBJECT_STORAGE_PROVIDER=r2
SMARTFLN_OBJECT_STORAGE_BUCKET=<cloudflare-r2-bucket-name>
SMARTFLN_R2_ACCOUNT_ID=<cloudflare-r2-account-id>
SMARTFLN_R2_ACCESS_KEY_ID=<cloudflare-r2-access-key-id>
SMARTFLN_R2_SECRET_ACCESS_KEY=<cloudflare-r2-secret-access-key>
SMARTFLN_R2_ENDPOINT_URL=https://<cloudflare-r2-account-id>.r2.cloudflarestorage.com
SMARTFLN_EXPORT_RETENTION_DAYS=7
SMARTFLN_RATE_LIMIT_WINDOW_MS=60000
SMARTFLN_RATE_LIMIT_MAX=300
SMARTFLN_SEED_DEMO_USERS=false
SMARTFLN_SMS_PROVIDER=twilio
SMARTFLN_TWILIO_ACCOUNT_SID=<twilio-account-sid>
SMARTFLN_TWILIO_AUTH_TOKEN=<twilio-auth-token>
SMARTFLN_TWILIO_FROM_NUMBER=<twilio-from-number>
SMARTFLN_EMAIL_PROVIDER=resend
SMARTFLN_RESEND_API_KEY=<resend-api-key>
SMARTFLN_EMAIL_FROM=SmartFLN <noreply@smartfln.vercel.app>
SMARTFLN_SENTRY_DSN=<sentry-dsn>
